-- exploartory data analysis 

select *
from layoff_staging2;

-- Get the minimum and maximum number of layoffs (3,12000)
select min(total_laid_off),max(total_laid_off)
from layoff_staging2;

-- Show rows where layoffs reached 100% (company fully laid off employees)
select *
from layoff_staging2
where layoff_staging2.percentage_laid_off=1;

-- Sum layoffs per company, sort descending, and get top 3 companies (Amazon ,Google ,Meta)
select company,sum(total_laid_off)
from layoff_staging2
group by company
order by 2 desc
limit 3;

-- Get the earliest and latest dates in the dataset (2020-03-11	,2023-03-06)
select min(`date`),max(`date`)
from layoff_staging2;

-- Sum layoffs by industry, sort ascending (least affected industries) (Manufacturing,Fin-Tech,Aerospace,Energy,Legal)
select industry,sum(total_laid_off)
from layoff_staging2
group by industry
order by 2 asc
limit 10 ;

-- Sum layoffs by industry, sort ascending (highest affected industries) (Consumer ,Retail ,Other , Transportation)
select industry,sum(total_laid_off)
from layoff_staging2
group by industry
order by 2 desc
limit 10;

-- Sum layoffs by country, sort descending (most affected countries) (United States,India,Netherlands)
select country,sum(total_laid_off)
from layoff_staging2
group by country
order by 2 desc
limit 3 ;

-- Sum layoffs by year to see which year had the highest layoffs (the highest one is 2022)
select year(`date`),sum(total_laid_off)
from layoff_staging2
group by  year(`date`) 
order by 2 desc;

-- Rolling Total of Layoffs Per Month
SELECT SUBSTRING(date,1,7) as dates, SUM(total_laid_off) AS total_laid_off
FROM layoff_staging2
GROUP BY dates
ORDER BY dates ASC;

-- now use it in a CTE so we can query off of it
WITH DATE_CTE AS 
(
SELECT SUBSTRING(`date`,1,7) as dates, SUM(total_laid_off) AS total_laid_off
FROM layoff_staging2
GROUP BY dates
ORDER BY dates ASC
)
SELECT dates, SUM(total_laid_off) OVER (ORDER BY dates ) as rolling_total_layoffs ,total_laid_off
FROM DATE_CTE
where dates is not null;

-- Create a CTE to calculate total layoffs per company per year
WITH Company_Year AS 
(
  SELECT company, YEAR(`date`) AS years, SUM(total_laid_off) AS total_laid_off
  FROM layoff_staging2
  GROUP BY company, YEAR(`date`)
)
, Company_Year_Rank AS (
  SELECT company, years, total_laid_off, DENSE_RANK() OVER (PARTITION BY years ORDER BY total_laid_off DESC) AS ranking
  FROM Company_Year
)
-- Select top 3 companies per year based on layoffs ( Uber, Booking.com, Groupon)
SELECT company, years, total_laid_off, ranking
FROM Company_Year_Rank
WHERE ranking <= 3
AND years IS NOT NULL
ORDER BY years ASC, total_laid_off DESC;

